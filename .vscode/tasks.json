{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run Vite Dev Server",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"dev",
				"--",
				"--host",
				"127.0.0.1"
			],
			"isBackground": true,
			"group": "build"
		},
		{
			"label": "Run Vite Dev Server via absolute npm",
			"type": "shell",
			"command": "C:\\Program Files\\nodejs\\npm.cmd",
			"args": [
				"run",
				"dev",
				"--",
				"--host",
				"127.0.0.1"
			],
			"isBackground": true,
			"group": "build"
		},
		{
			"label": "Run Vite Dev Server direct node",
			"type": "shell",
			"command": "C:\\Program Files\\nodejs\\node.exe",
			"args": [
				"./node_modules/vite/bin/vite.js",
				"--host",
				"127.0.0.1"
			],
			"isBackground": true,
			"group": "build"
		}
	]
}